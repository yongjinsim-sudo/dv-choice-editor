{
  "name": "dv-choice-editor",
  "displayName": "DV Choice Editor",
  "description": "Preview-first Dataverse choice and option set management for VS Code.",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other",
    "Data Science"
  ],
  "license": "MIT",
  "activationEvents": [
    "onCommand:dvChoiceEditor.openChoiceEditor"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dvChoiceEditor.openChoiceEditor",
        "title": "DV Choice Editor: Open Choice Editor"
      }
    ],
    "configuration": {
      "title": "DV Choice Editor",
      "properties": {
        "dvChoiceEditor.environments": {
          "type": "array",
          "default": [],
          "description": "Dataverse environments available to DV Choice Editor.",
          "items": {
            "type": "object",
            "required": [
              "name",
              "url"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Environment label, for example DEV or SIT."
              },
              "url": {
                "type": "string",
                "description": "Dataverse environment URL, for example https://org.crm6.dynamics.com."
              },
              "tenantId": {
                "type": "string",
                "description": "Optional tenant ID for Azure CLI token acquisition."
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "keywords": [
    "dataverse",
    "power platform",
    "dynamics 365",
    "choices",
    "choice",
    "optionset",
    "option set",
    "picklist",
    "metadata",
    "dvforgelab",
    "powerapps",
    "power apps",
    "crm",
    "model driven app",
    "microsoft dataverse"
  ],
  "publisher": "dv-forgelab",
  "icon": "images/dv-utilities-icon-128.png",
    "repository": {
    "type": "git",
    "url": "https://github.com/yongjinsim-sudo/dv-choice-editor"
  },
  "bugs": {
    "url": "https://github.com/yongjinsim-sudo/dv-choice-editor/issues"
  },
  "homepage": "https://github.com/yongjinsim-sudo/dv-choice-editor"
}
